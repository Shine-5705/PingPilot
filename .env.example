# Core app
DATABASE_URL=sqlite:///pingpilot.db
REDIS_URL=

# Crustdata
CRUSTDATA_API_KEY=your_crustdata_api_key
CRUSTDATA_API_VERSION=2025-11-01
CRUSTDATA_BASE_URL=https://api.crustdata.com
CRUSTDATA_PEOPLE_SEARCH_PATH=/people/search
CRUSTDATA_PEOPLE_AUTOCOMPLETE_PATH=/person/search/autocomplete
CRUSTDATA_PERSON_ENRICH_PATH=/person/enrich

# LLM providers (use one or both)
GROK_API_KEY=your_grok_api_key
GEMINI_API_KEY=your_gemini_api_key
SARVAM_API_KEY=your_sarvam_api_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP email sender
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=you@yourdomain.com
